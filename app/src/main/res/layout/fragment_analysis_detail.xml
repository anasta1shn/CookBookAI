<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="104dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="310dp">

            <ImageView
                android:id="@+id/imageFoodDetail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/bg_secondary"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:id="@+id/imagePlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/surface_soft"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="28dp">

                <FrameLayout
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:background="@drawable/bg_upload_icon_circle">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:contentDescription="Фото не загружено"
                        android:src="@drawable/ic_camera_upload" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Фото не загружено"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:text="Результат анализа сохранён без изображения"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/buttonBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="18dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_circle_light"
                android:contentDescription="Назад"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_back_24"
                android:tint="@color/accent_dark" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-34dp"
            android:background="@drawable/bg_soft_panel"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <View
                android:layout_width="54dp"
                android:layout_height="5dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_macro_bar" />

            <TextView
                android:id="@+id/textDishName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_input_soft"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp"
                android:text="Название блюда"
                android:textColor="@color/text_primary"
                android:textSize="21sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="76dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_soft"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Калории"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textCalories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0 ккал"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="76dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_soft"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Вес"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textWeight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0 г"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/textMacros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_soft_panel_gray"
                android:padding="16dp"
                android:text="Б 0 | Ж 0 | У 0"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textIndividualMacros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_soft_panel_gray"
                android:lineSpacingExtra="3dp"
                android:padding="16dp"
                android:text="КБЖУ по продуктам"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSave"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="20dp"
                android:text="Сохранить в историю"
                android:textAllCaps="false"
                android:textColor="@color/on_accent"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/accent_primary"
                app:cornerRadius="28dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="AI-детали"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textConfidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_soft_panel_gray"
                android:padding="16dp"
                android:text="AI confidence: 0%"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textTopPredictions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_soft_panel_gray"
                android:padding="16dp"
                android:text="Top-3 predictions"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/textAiSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_soft_panel_gray"
                android:lineSpacingExtra="3dp"
                android:padding="16dp"
                android:text="AI Summary"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonExportPdf"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:text="Поделиться"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="14dp"
                app:strokeColor="@color/text_primary"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonDelete"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:text="Удалить анализ"
                android:textAllCaps="false"
                android:textColor="@color/accent_secondary"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="14dp"
                app:strokeColor="@color/stroke_light"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
