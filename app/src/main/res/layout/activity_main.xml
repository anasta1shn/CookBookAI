<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Контейнер фрагментов -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Нижняя карточка навигации -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomNavCard"
        android:layout_width="0dp"
        android:layout_height="82dp"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="@dimen/bottom_nav_margin_bottom"
        app:cardBackgroundColor="@color/bottom_nav_bg"
        app:cardCornerRadius="0dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="9dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/navRecipes"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="4dp">

                <ImageView
                    android:id="@+id/navIconRecipes"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_home"
                    android:tint="@color/bottom_nav_item_unselected" />

                <TextView
                    android:id="@+id/navTextRecipes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:singleLine="true"
                    android:text="Главная"
                    android:textColor="@color/bottom_nav_item_unselected"
                    android:textSize="9.5sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navFavorites"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="4dp">

                <ImageView
                    android:id="@+id/navIconFavorites"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_heart"
                    android:tint="@color/bottom_nav_item_unselected" />

                <TextView
                    android:id="@+id/navTextFavorites"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:singleLine="true"
                    android:text="Избранное"
                    android:textColor="@color/bottom_nav_item_unselected"
                    android:textSize="9.5sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Space
                android:id="@+id/navAddSlot"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/navAi"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="4dp">

                <ImageView
                    android:id="@+id/navIconAi"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_ai"
                    android:tint="@color/bottom_nav_item_unselected" />

                <TextView
                    android:id="@+id/navTextAi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:singleLine="true"
                    android:text="ИИ-анализ"
                    android:textColor="@color/bottom_nav_item_unselected"
                    android:textSize="9.5sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navAccount"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="4dp">

                <ImageView
                    android:id="@+id/navIconAccount"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_account"
                    android:tint="@color/bottom_nav_item_unselected" />

                <TextView
                    android:id="@+id/navTextAccount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:singleLine="true"
                    android:text="Профиль"
                    android:textColor="@color/bottom_nav_item_unselected"
                    android:textSize="9.5sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Кнопка добавления рецепта -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnAddRecipe"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:clickable="true"
        android:elevation="18dp"
        android:focusable="true"
        android:translationY="-18dp"
        android:translationZ="18dp"
        app:cardBackgroundColor="@color/accent_primary"
        app:cardCornerRadius="28dp"
        app:cardElevation="18dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/bottomNavCard"
        app:rippleColor="@color/nav_active_bg">

        <ImageView
            android:id="@+id/iconAdd"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_add"
            android:tint="@color/on_accent" />

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
