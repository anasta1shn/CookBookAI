<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="104dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_recipes_header"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="10dp"
                android:text="Профиль"
                android:textColor="@color/on_accent"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.9"
                android:text="Настройки и данные аккаунта"
                android:textColor="@color/on_accent"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="20dp"
            app:cardBackgroundColor="@color/surface_soft"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/profileImage"
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:background="@drawable/profile_circle_bg"
                    android:padding="14dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_account" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/profileName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Пользователь"
                        android:textColor="@color/text_primary"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/profileEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="email@example.com"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/profileCategory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Любимая категория: -"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/profileStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_soft_panel"
            android:padding="18dp"
            android:text="Рецептов: 0   Избранных: 0"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="34dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="20dp"
            android:text="Персонализация"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_soft_panel"
            android:orientation="vertical"
            android:paddingHorizontal="18dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFavorites"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:gravity="center_vertical"
                android:text="Избранные рецепты"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="0dp"
                app:icon="@android:drawable/ic_menu_compass"
                app:iconGravity="end"
                app:iconTint="@color/text_muted" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/stroke_light" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStats"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:gravity="center_vertical"
                android:text="Моя статистика"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="0dp"
                app:icon="@android:drawable/ic_menu_compass"
                app:iconGravity="end"
                app:iconTint="@color/text_muted" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/stroke_light" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistory"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:gravity="center_vertical"
                android:text="История ИИ-анализа"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="0dp"
                app:icon="@android:drawable/ic_menu_compass"
                app:iconGravity="end"
                app:iconTint="@color/text_muted" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="34dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="20dp"
            android:text="Настройки"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_soft_panel"
            android:orientation="vertical"
            android:paddingHorizontal="18dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTheme"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:gravity="center_vertical"
                android:text="Тема приложения"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="0dp"
                app:icon="@android:drawable/ic_menu_compass"
                app:iconGravity="end"
                app:iconTint="@color/text_muted" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/stroke_light" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnServerAddress"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:gravity="center_vertical"
                android:text="Адрес сервера"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="0dp"
                app:icon="@android:drawable/ic_menu_manage"
                app:iconGravity="end"
                app:iconTint="@color/text_muted" />

            <TextView
                android:id="@+id/textServerAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingBottom="12dp"
                android:text="http://10.2.30.45:8000/"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/stroke_light" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:gravity="center_vertical"
                android:text="Выйти"
                android:textAllCaps="false"
                android:textColor="@color/accent_secondary"
                android:textSize="16sp"
                android:layout_marginBottom="20dp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="0dp"
                app:icon="@android:drawable/ic_menu_compass"
                app:iconGravity="end"
                app:iconTint="@color/text_muted" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
